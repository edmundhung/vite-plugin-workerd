{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"baseUrl": ".",
		"paths": {
			"vite-plugin-workerd": ["../../src/index.ts"]
		},
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"isolatedModules": true,
		"resolveJsonModule": true,
		"skipLibCheck": true,
		"types": ["node", "@cloudflare/workers-types", "vitest/globals"]
	},
	"include": ["src/**/*.ts", "workerd.config.ts", "vite.config.ts", "tests/**/*.ts"]
}
